datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password       String
  role           String
  isVerified     Boolean   @default(false)
  signupOtp      String?
  signupOtpExpiry DateTime?
  resetOtp       String?
  resetOtpExpiry DateTime?
}
